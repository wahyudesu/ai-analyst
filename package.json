{
  "name": "ai-analyst",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter api dev\" \"pnpm --filter web dev\" --names \"api,web\" --prefix-colors \"cyan,magenta\" --hide \"none\"",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "start": "pnpm -r start",
    "start:api": "pnpm --filter api start",
    "start:web": "pnpm --filter web start",
    "clean": "rm -rf node_modules api/node_modules web/node_modules api/dist web/.next",
    "clean:api": "rm -rf api/node_modules api/dist",
    "clean:web": "rm -rf web/node_modules web/.next",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format --check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
  "dependencies": {
    "better-auth": "^1.4.18",
    "recharts": "^3.8.0"
  }
}
